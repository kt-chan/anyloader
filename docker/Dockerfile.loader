FROM python:3.13-slim

WORKDIR /app

# Install dependencies
COPY docker/requirements_loader.txt .
RUN pip install --no-cache-dir -r requirements_loader.txt

# Copy source code
COPY src/ /app/src/

# Ingest script needs access to data directory
# This should be mounted as a volume in docker-compose

CMD ["python", "src/loader/ingest.py"]
