FROM python:3.13-slim

WORKDIR /app

# Install dependencies
COPY docker/requirements_server.txt .
RUN pip install --no-cache-dir -r requirements_server.txt

# Copy source code
COPY src/ /app/src/

# Create storage and temp directories
RUN mkdir -p storage/lancedb storage/temp

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "src.server.main:app", "--host", "0.0.0.0", "--port", "8000"]
